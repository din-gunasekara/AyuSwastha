<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <appSettings>
    <!-- SQLite database file (created next to the executable on first run). -->
    <add key="DatabaseFile" value="AyuSwastha.db" />
  </appSettings>
</configuration>
